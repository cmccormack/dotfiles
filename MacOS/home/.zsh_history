: 1742007440:0;echo "WAN Interface State Change Report" > wan_report.txt\
echo "-------------------------------" >> wan_report.txt\
echo -e "Timestamp\t\t\t| Interface\t| State\t| Duration" >> wan_report.txt\
echo "-------------------------------" >> wan_report.txt\
\
# Process the data to include durations between state changes\
awk 'BEGIN {prev_time=""; prev_state=""} \
{\
  split($1, dt, "T");\
  split($1, t, "-07:00");\
  currtime = t[1];\
  \
  if (prev_time != "" && prev_state != $NF) {\
    cmd = "date -u -j -f \"%Y-%m-%dT%H:%M:%S\" \"" prev_time "\" +%s";\
    cmd | getline prev_epoch;\
    close(cmd);\
    \
    cmd = "date -u -j -f \"%Y-%m-%dT%H:%M:%S\" \"" currtime "\" +%s";\
    cmd | getline curr_epoch;\
    close(cmd);\
    \
    diff = curr_epoch - prev_epoch;\
    minutes = int(diff / 60);\
    seconds = diff % 60;\
    \
    if (prev_state == "down") {\
      duration = minutes "m " seconds "s downtime";\
    } else {\
      duration = minutes "m " seconds "s uptime";\
    }\
  } else {\
    duration = "-";\
  }\
  \
  printf "%s | %s | %s | %s\n", $1, $3" "$4, $NF, duration;\
  \
  prev_time = currtime;\
  prev_state = $NF;\
}' <(grep "wan-failover-interfaces" parsed_output.log | \
     sed -E 's/^([^ ]+).+wf-interface-([^ ]+) \(([^)]+)\) is (up|down).+$/\1 \2 \3 \4/' | \
     sort) >> wan_report.txt\
\
cat wan_report.txt\

: 1742007461:0;# Create improved report with better formatting and summary statistics\
{\
  echo "WAN Interface State Change Report for eth8 (98.165.236.209)"\
  echo "============================================================"\
  echo\
  printf "%-25s | %-10s | %-15s\n" "Timestamp" "State" "Duration"\
  echo "------------------------------------------------------------"\
  \
  # Variables for summary statistics\
  awk 'BEGIN {total_downtime=0; total_uptime=0; down_events=0; up_events=0}\
  {\
    split($0, parts, " | ");\
    timestamp = parts[1];\
    state = parts[3];\
    duration = parts[4];\
    \
    # Format the output\
    printf "%-25s | %-10s | %-15s\n", timestamp, state, duration;\
    \
    # Calculate statistics\
    if (state == "down") {\
      down_events++;\
    } else if (state == "up") {\
      up_events++;\
      \
      # Extract downtime duration if available\
      if (duration ~ /downtime/) {\
        split(duration, d, "downtime");\
        gsub(/[^0-9]/, " ", d[1]);\
        split(d[1], time_parts, " ");\
        minutes = time_parts[1];\
        seconds = time_parts[2];\
        total_downtime += (minutes * 60) + seconds;\
      }\
    }\
    \
    # Extract uptime duration if available\
    if (duration ~ /uptime/) {\
      split(duration, d, "uptime");\
      gsub(/[^0-9]/, " ", d[1]);\
      split(d[1], time_parts, " ");\
      minutes = time_parts[1];\
      seconds = time_parts[2];\
      total_uptime += (minutes * 60) + seconds;\
    }\
  }\
  END {\
    # Calculate total monitored time\
    total_time = total_uptime + total_downtime;\
    \
    # Convert seconds to more readable format\
    function format_time(seconds) {\
      days = int(seconds / 86400);\
      hours = int((seconds % 86400) / 3600);\
      minutes = int((seconds % 3600) / 60);\
      secs = seconds % 60;\
      \
      result = "";\
      if (days > 0) result = result days "d ";\
      if (hours > 0) result = result hours "h ";\
      if (minutes > 0) result = result minutes "m ";\
      if (secs > 0) result = result secs "s";\
      \
      return result;\
    }\
    \
    # Calculate availability percentage\
    availability = 0;\
    if (total_time > 0) {\
      availability = (total_uptime / total_time) * 100;\
    }\
    \
    # Print summary statistics\
    print "\nSummary Statistics";\
    print "=================";\
    printf "Total down events: %d\n", down_events;\
    printf "Total up events: %d\n", up_events;\
    printf "Total downtime: %s\n", format_time(total_downtime);\
    printf "Total uptime: %s\n", format_time(total_uptime);\
    printf "Monitoring period: %s\n", format_time(total_time);\
    printf "Availability: %.2f%%\n", availability;\
    \
    # Calculate average downtime\
    if (down_events > 0) {\
      avg_downtime = total_downtime / down_events;\
      printf "Average downtime per incident: %s\n", format_time(avg_downtime);\
    }\
  }' wan_report.txt | grep -v "\-\-\-\-\-\-"\
} > improved_wan_report.txt\
\
cat improved_wan_report.txt\

: 1742007488:0;# Extract the data lines for processing\
grep -v "^WAN Interface\|^-\|^Timestamp" wan_report.txt > temp_data.txt\
\
# Create an improved report with summary statistics\
{\
  echo "WAN Interface State Change Report for eth8 (98.165.236.209)"\
  echo "============================================================"\
  echo\
  printf "%-25s | %-10s | %-15s\n" "Timestamp" "State" "Duration"\
  echo "------------------------------------------------------------"\
  cat temp_data.txt\
  \
  # Calculate summary statistics\
  echo -e "\nSummary Statistics"\
  echo "================="\
  \
  # Count down events\
  down_events=$(grep " down " temp_data.txt | wc -l)\
  echo "Total down events: $down_events"\
  \
  # Count up events\
  up_events=$(grep " up " temp_data.txt | wc -l)\
  echo "Total up events: $up_events"\
  \
  # Calculate total downtime (in seconds)\
  total_downtime=$(grep "downtime" temp_data.txt | awk -F'downtime' '{gsub(/[^0-9]/, " ", $1); split($1, t, " "); sum += (t[length(t)-1]*60) + t[length(t)]} END {print sum}')\
  \
  # Format downtime in a readable way\
  days=$((total_downtime / 86400))\
  hours=$(((total_downtime % 86400) / 3600))\
  minutes=$(((total_downtime % 3600) / 60))\
  seconds=$((total_downtime % 60))\
  \
  if [ $days -gt 0 ]; then\
    formatted_downtime="${days}d ${hours}h ${minutes}m ${seconds}s"\
  elif [ $hours -gt 0 ]; then\
    formatted_downtime="${hours}h ${minutes}m ${seconds}s"\
  else\
    formatted_downtime="${minutes}m ${seconds}s"\
  fi\
  \
  echo "Total downtime: $formatted_downtime"\
  \
  # Calculate total uptime (in seconds)\
  total_uptime=$(grep "uptime" temp_data.txt | awk -F'uptime' '{gsub(/[^0-9]/, " ", $1); split($1, t, " "); sum += (t[length(t)-1]*60) + t[length(t)]} END {print sum}')\
  \
  # Format uptime in a readable way\
  days=$((total_uptime / 86400))\
  hours=$(((total_uptime % 86400) / 3600))\
  minutes=$(((total_uptime % 3600) / 60))\
  seconds=$((total_uptime % 60))\
  \
  if [ $days -gt 0 ]; then\
    formatted_uptime="${days}d ${hours}h ${minutes}m ${seconds}s"\
  elif [ $hours -gt 0 ]; then\
    formatted_uptime="${hours}h ${minutes}m ${seconds}s"\
  else\
    formatted_uptime="${minutes}m ${seconds}s"\
  fi\
  \
  echo "Total uptime: $formatted_uptime"\
  \
  # Calculate total monitored time\
  total_time=$((total_downtime + total_uptime))\
  days=$((total_time / 86400))\
  hours=$(((total_time % 86400) / 3600))\
  minutes=$(((total_time % 3600) / 60))\
  seconds=$((total_time % 60))\
  \
  if [ $days -gt 0 ]; then\
    formatted_total_time="${days}d ${hours}h ${minutes}m ${seconds}s"\
  elif [ $hours -gt 0 ]; then\
    formatted_total_time="${hours}h ${minutes}m ${seconds}s"\
  else\
    formatted_total_time="${minutes}m ${seconds}s"\
  fi\
  \
  echo "Monitoring period: $formatted_total_time"\
  \
  # Calculate availability percentage\
  if [ $total_time -gt 0 ]; then\
    availability=$(awk -v up="$total_uptime" -v total="$total_time" 'BEGIN {printf "%.2f", (up/total)*100}')\
    echo "Availability: ${availability}%"\
  else\
    echo "Availability: N/A (insufficient data)"\
  fi\
  \
  # Calculate average downtime per incident\
  if [ $down_events -gt 0 ]; then\
    avg_downtime=$((total_downtime / down_events))\
    minutes=$((avg_downtime / 60))\
    seconds=$((avg_downtime % 60))\
    echo "Average downtime per incident: ${minutes}m ${seconds}s"\
  fi\
} > improved_wan_report.txt\
\
cat improved_wan_report.txt\
\
# Clean up temporary file\
rm temp_data.txt\

: 1742007506:0;# Extract just the needed data and reformat it\
{\
  echo "WAN Interface State Change Report for eth8 (98.165.236.209)"\
  echo "============================================================"\
  echo\
  printf "%-25s | %-8s | %-15s\n" "Timestamp" "State" "Duration"\
  echo "------------------------------------------------------------"\
  \
  # Process and clean up the data rows\
  cat temp_data.txt | sed -E 's/^([^|]+)\| ([^|]+) ([^|]+) \| ([^|]+) \| (.+)$/\1| \4 | \5/' | sort\
  \
  # Copy the summary statistics as they are good\
  grep -A20 "Summary Statistics" improved_wan_report.txt\
} > final_wan_report.txt\
\
cat final_wan_report.txt\

: 1742007523:0;# Create the final clean report\
{\
  echo "WAN Interface State Change Report for eth8 (98.165.236.209)"\
  echo "============================================================"\
  echo\
  printf "%-25s | %-8s | %-15s\n" "Timestamp" "State" "Duration"\
  echo "------------------------------------------------------------"\
  \
  # Process the parsed_output.log to create clean data rows\
  grep "wan-failover-interfaces" parsed_output.log | \
    awk 'BEGIN {prev_time=""; prev_state=""} \
    {\
      # Extract timestamp and state\
      timestamp = $1;\
      if (match($0, /is (up|down)/, state_match)) {\
        current_state = state_match[1];\
        \
        # Calculate duration\
        if (prev_time != "" && prev_state != current_state) {\
          cmd = "date -u -j -f \"%Y-%m-%dT%H:%M:%S\" \"" substr(prev_time, 1, 19) "\" +%s";\
          cmd | getline prev_epoch;\
          close(cmd);\
          \
          cmd = "date -u -j -f \"%Y-%m-%dT%H:%M:%S\" \"" substr(timestamp, 1, 19) "\" +%s";\
          cmd | getline curr_epoch;\
          close(cmd);\
          \
          diff = curr_epoch - prev_epoch;\
          minutes = int(diff / 60);\
          seconds = diff % 60;\
          \
          if (prev_state == "down") {\
            duration = minutes "m " seconds "s downtime";\
          } else {\
            duration = minutes "m " seconds "s uptime";\
          }\
        } else {\
          duration = "-";\
        }\
        \
        # Print the formatted line\
        printf "%-25s | %-8s | %-15s\n", timestamp, current_state, duration;\
        \
        prev_time = timestamp;\
        prev_state = current_state;\
      }\
    }' | sort\
  \
  # Keep the summary statistics from the previous report\
  grep -A20 "Summary Statistics" improved_wan_report.txt\
} > final_wan_report.txt\
\
cat final_wan_report.txt\

: 1742007541:0;# Create the final report with clean data and proper formatting\
{\
  echo "WAN Interface State Change Report for eth8 (98.165.236.209)"\
  echo "============================================================"\
  echo\
  printf "%-25s | %-8s | %-15s\n" "Timestamp" "State" "Duration"\
  echo "------------------------------------------------------------"\
  \
  # Extract and format the data from the original report\
  sed -n '/^2025/p' wan_report.txt | sed 's/98.165.236.209 \(up\|down\) | \(up\|down\)/\2/g' | sort\
  \
  # Keep the summary statistics from the previous report\
  grep -A20 "Summary Statistics" improved_wan_report.txt\
} > final_wan_report.txt\
\
cat final_wan_report.txt\

: 1742007555:0;# Create a cleanly formatted final report using a more direct approach\
{\
  echo "WAN Interface State Change Report for eth8 (98.165.236.209)"\
  echo "============================================================"\
  echo\
  printf "%-25s | %-8s | %-20s\n" "Timestamp" "State" "Duration"\
  echo "------------------------------------------------------------"\
  \
  # Process each line manually with cut and paste to ensure proper formatting\
  sed -n '/^2025/p' wan_report.txt | while read line; do\
    timestamp=$(echo "$line" | cut -d'|' -f1 | sed 's/ *$//')\
    state=$(echo "$line" | sed 's/.* | \(up\|down\) | .*/\1/')\
    duration=$(echo "$line" | cut -d'|' -f3-)\
    \
    printf "%-25s | %-8s | %-20s\n" "$timestamp" "$state" "$duration"\
  done\
  \
  # Keep the summary statistics from the previous report\
  grep -A20 "Summary Statistics" improved_wan_report.txt\
} > final_wan_report.txt\
\
cat final_wan_report.txt\

