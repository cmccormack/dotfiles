{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch(*)",
      "WebFetch(domain:partner.steamgames.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:reddit.com)",
      "WebFetch(domain:www.reddit.com)",
      "WebFetch(domain:steamcommunity.com)",
      "WebFetch(domain:www.steamcommunity.com)",
      "WebFetch(domain:store.steampowered.com)",
      "WebFetch(domain:wiki.facepunch.com)",
      "WebFetch(domain:steamdb.info)",
      "WebFetch(domain:protondb.com)",
      "WebFetch(domain:www.protondb.com)",
      "WebFetch(domain:lutris.net)",
      "WebFetch(domain:heroicgameslauncher.com)",
      "WebFetch(domain:gamingonlinux.com)",
      "WebFetch(domain:www.gamingonlinux.com)",
      "WebFetch(domain:nicedoc.io)",
      "WebFetch(domain:pcgamingwiki.com)",
      "WebFetch(domain:www.pcgamingwiki.com)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Write(/Users/chris/Projects/steamdeck/.claude/research/*)",
      "Write(/Users/chris/Projects/steamdeck/.claude/cache/*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git notes *)",
      "Bash(pwd)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(jq *)",
      "Bash(xargs *)",
      "Bash(strings *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(tar *)",
      "Bash(unzip *)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|Read|Agent|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/log-tool-use.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/log-session-stop.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline/statusline.sh"
  },
  "effortLevel": "high",
  "voice": {
    "mode": "hold",
    "autoSubmit": true
  },
  "theme": "dark",
  "voiceEnabled": true
}
